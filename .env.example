# ─────────────────────────────────────────────────────────────
# InkShelf environment variables
# Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────

# MongoDB connection string (optional but required for accounts, favorites,
# and reading shelves). Without it the app runs in "browse-only" mode and
# persistence features degrade gracefully.
# Example: mongodb+srv://user:pass@cluster.mongodb.net/inkshelf
MONGODB_URI=

# NextAuth — required.
# Generate a secret with:  openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — enables "Continue with Google").
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_ID=
GOOGLE_SECRET=
